POSTGRES_DB=vetai_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DEBUG=false
ENABLE_REALTIME=false
BACKEND_IMAGE=ovs-redo-backend:latest
FRONTEND_IMAGE=ovs-redo-frontend:latest
BACKEND_PORT=8000
FRONTEND_PORT=80
DATABASE_URL=
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

FLOWER_PORT=5555
FLOWER_REQUIRE_AUTH=false
FLOWER_BASIC_AUTH=

AI_ML_METRIC_GATES_ENABLED=true
AI_ML_TRAINING_REPORT_PATH=models/training_report.json
AI_ML_DOC_CLASSIFIER_REPORT_PATH=models/document_classifier_training_report.json
AI_ML_METRIC_MIN_AUTHENTICITY_F1=0.70
AI_ML_METRIC_MIN_AUTHENTICITY_ACCURACY=0.70
AI_ML_METRIC_MIN_SIGNATURE_F1=0.70
AI_ML_METRIC_MIN_SIGNATURE_ACCURACY=0.70
AI_ML_METRIC_MIN_RVL_CDIP_MACRO_F1=0.60
AI_ML_METRIC_MIN_MIDV500_MACRO_F1=0.40
BACKGROUND_CHECK_DEFAULT_PROVIDER=http
BACKGROUND_CHECK_WEBHOOK_TOKEN=replace-me
BACKGROUND_CHECK_HTTP_BASE_URL=
BACKGROUND_CHECK_HTTP_API_KEY=