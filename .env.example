FRONTEND_PORT=80
DATABASE_URL=
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
DJANGO_API_URL=http://localhost:8000

FLOWER_PORT=5555
FLOWER_REQUIRE_AUTH=false
FLOWER_BASIC_AUTH=

AI_ML_METRIC_GATES_ENABLED=true
AI_ML_PREFLIGHT_IMPORT_TIMEOUT_SECONDS=20
# Production-enforced minimums are validated in config.settings.production.
