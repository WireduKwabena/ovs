# -----------------------------------------------------------------------------
# Production compose environment
# Copy to `.env` (or pass with `--env-file`) before running docker-compose.prod.yml
# -----------------------------------------------------------------------------

# Prebuilt images
BACKEND_IMAGE=ovs-redo-backend:latest
FRONTEND_IMAGE=ovs-redo-frontend:latest

# Exposed host ports
BACKEND_PORT=8000
FRONTEND_PORT=80
FLOWER_PORT=5555

# Django runtime
DEBUG=false
ENABLE_REALTIME=true
SECRET_KEY=replace-with-a-strong-secret-key
ALLOWED_HOSTS=your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com
FRONTEND_URL=https://your-domain.com
DJANGO_API_URL=https://api.your-domain.com

# Email (SMTP in production)
# EMAIL_BACKEND is optional because production settings force SMTP backend.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-smtp-user@example.com
EMAIL_HOST_PASSWORD=your-smtp-password-or-app-password
DEFAULT_FROM_EMAIL="OVS Team <noreply@your-domain.com>"

# Hosted PostgreSQL (required by config.settings.production)
DATABASE_URL=postgresql://db_user:db_password@db-host.example.com:5432/db_name

# Redis/Celery
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=2
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Flower
FLOWER_REQUIRE_AUTH=true
FLOWER_BASIC_AUTH=admin:change-me

# AI/ML quality + governance
AI_ML_MODEL_MANIFEST_PATH=models/model_manifest.json
AI_ML_MODEL_MANIFEST_REQUIRED=true
AI_ML_METRIC_GATES_ENABLED=true
AI_ML_PREFLIGHT_IMPORT_TIMEOUT_SECONDS=20
AI_ML_METRIC_MIN_AUTHENTICITY_F1=0.70
AI_ML_METRIC_MIN_AUTHENTICITY_ACCURACY=0.70
AI_ML_METRIC_MIN_SIGNATURE_F1=0.90
AI_ML_METRIC_MIN_SIGNATURE_ACCURACY=0.90
AI_ML_METRIC_MIN_RVL_CDIP_MACRO_F1=0.60
AI_ML_METRIC_MIN_MIDV500_MACRO_F1=0.40

# Data retention policy (days)
PII_RETENTION_DAYS=365
BIOMETRIC_RETENTION_DAYS=180
BACKGROUND_CHECK_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=730


# Billing/Stripe
BILLING_SUBSCRIPTION_TICKET_TTL_HOURS=24
BILLING_SUBSCRIPTION_VERIFY_RATE_LIMIT_ENABLED=true
BILLING_SUBSCRIPTION_VERIFY_RATE_LIMIT_PER_MINUTE=30
BILLING_HEALTH_REQUIRE_STAFF=true
INTERVIEWS_TASK_INLINE_FALLBACK_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=USD
PAYSTACK_USD_EXCHANGE_RATE=1.0
EXCHANGE_RATE_API_URL=
EXCHANGE_RATE_API_TIMEOUT_SECONDS=8
EXCHANGE_RATE_CACHE_TTL_SECONDS=3600
BACKGROUND_CHECK_DEFAULT_PROVIDER=http
BACKGROUND_CHECK_WEBHOOK_TOKEN=replace-with-a-strong-random-token
BACKGROUND_CHECK_HTTP_BASE_URL=https://provider.example.com
BACKGROUND_CHECK_HTTP_API_KEY=replace-with-provider-api-key
STRIPE_BILLING_PORTAL_RETURN_URL=https://your-domain.com/settings
PAYSTACK_WEBHOOK_SECRET=
SERVICE_TOKEN=replace-with-service-to-service-token

# LiveKit (video meeting runtime)
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=3600
VIDEO_CALLS_MAX_REMINDER_BEFORE_MINUTES=120
