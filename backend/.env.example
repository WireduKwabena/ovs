# AI_ML_METRIC_MIN_AUTHENTICITY_ACCURACY=0.65
# AI_ML_METRIC_MIN_RVL_CDIP_MACRO_F1=0.50
# AI_ML_METRIC_MIN_MIDV500_MACRO_F1=0.20
# For local development use mock; for production use http
BACKGROUND_CHECK_DEFAULT_PROVIDER=mock
BACKGROUND_CHECK_REQUIRE_CONSENT=true
BACKGROUND_CHECK_WEBHOOK_TOKEN=
BACKGROUND_CHECK_HTTP_BASE_URL=
BACKGROUND_CHECK_HTTP_API_KEY=
