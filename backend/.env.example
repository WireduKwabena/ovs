# -----------------------------------------------------------------------------
# Core Django
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=true
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
DJANGO_API_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Development Database (localhost PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=online_veting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_FIRST_NAME=System
DJANGO_SUPERUSER_LAST_NAME=Admin
DJANGO_SUPERUSER_RESET_PASSWORD=false

# -----------------------------------------------------------------------------
# Production Database (hosted PostgreSQL)
# -----------------------------------------------------------------------------
# Example:
# DATABASE_URL=postgresql://db_user:db_password@db-host.example.com:5432/db_name
DATABASE_URL=

# -----------------------------------------------------------------------------
# Optional services
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CHANNELS_REDIS_URL=redis://localhost:6379/0
USE_REDIS=true
ENABLE_REALTIME=false
CELERY_EAGER=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_SEND_TASK_EVENTS=true
CELERY_TASK_SEND_SENT_EVENT=true
CELERY_BEAT_MAX_LOOP_INTERVAL=60
FLOWER_PORT=5555
FLOWER_REQUIRE_AUTH=false
# Optional basic auth in user:password format (recommended outside localhost)
FLOWER_BASIC_AUTH=
SERVICE_TOKEN=
# Email (DEBUG=true -> console backend; DEBUG=false -> SMTP backend by default)
# EMAIL_BACKEND is optional in production because SMTP is already default when DEBUG=false.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@vetting-system.com
SENTRY_DSN=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=default_professional_avatar
HEYGEN_VOICE_ID=40532bc2b15c49f2b0f4deee08ce674d
HEYGEN_FRONTEND_SDK_ENABLED=false
HEYGEN_AVATAR_QUALITY=medium
HEYGEN_AVATAR_ACTIVITY_IDLE_TIMEOUT=300
HEYGEN_AVATAR_LANGUAGE=en
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=3600
VIDEO_CALLS_JOIN_GRACE_MINUTES=30
VIDEO_CALLS_MAX_REMINDER_BEFORE_MINUTES=120
VIDEO_CALLS_REMINDER_RETRY_MAX_ATTEMPTS=3
VIDEO_CALLS_REMINDER_RETRY_BASE_SECONDS=60
VIDEO_CALLS_REMINDER_RETRY_MAX_SECONDS=900

# ---------------------------------------------------------------------------
# AI/ML scoring policy
# ---------------------------------------------------------------------------
AI_ML_APPROVAL_THRESHOLD=85
AI_ML_MANUAL_REVIEW_THRESHOLD=70
AI_ML_CONSISTENCY_WEIGHT_NAME=0.6
AI_ML_CONSISTENCY_WEIGHT_DATE=0.4
AI_ML_CONSISTENCY_APPROVE_THRESHOLD=85
AI_ML_CONSISTENCY_MANUAL_REVIEW_THRESHOLD=70
AI_ML_AUTHENTICITY_MODEL_PATH=models/authenticity_best.h5
AI_ML_AUTHENTICITY_TORCH_MODEL_PATH=models/authenticity_detector.pth
AI_ML_FRAUD_MODEL_PATH=models/fraud_classifier.pkl
AI_ML_SIGNATURE_MODEL_PATH=models/signature_authenticity.pkl
AI_ML_RVL_CDIP_MODEL_PATH=models/rvl_cdip_classifier.pkl
AI_ML_MIDV500_MODEL_PATH=models/midv500_classifier.pkl
AI_ML_PREFLIGHT_IMPORT_TIMEOUT_SECONDS=20
AI_ML_POPPLER_PATH=
AI_ML_IDENTITY_MATCH_THRESHOLD=0.72
AI_ML_IDENTITY_EMBEDDING_BACKEND=auto
AI_ML_IDENTITY_FACENET_WEIGHTS=vggface2
AI_ML_IDENTITY_VIDEO_SAMPLE_RATE=8
AI_ML_DOC_TYPE_MISMATCH_ENABLED=true
AI_ML_DOC_TYPE_MISMATCH_CONFIDENCE=0.65
AI_ML_SOCIAL_CONSENT_REQUIRED=true
AI_ML_SOCIAL_VERIFY_URLS=false
AI_ML_SOCIAL_HTTP_TIMEOUT=5.0
AI_ML_SOCIAL_ALLOWED_PLATFORMS=linkedin,github,x,facebook,instagram,tiktok
AI_ML_TRAINING_REPORT_PATH=models/training_report.json
AI_ML_DOC_CLASSIFIER_REPORT_PATH=models/document_classifier_training_report.json
AI_ML_MODEL_MANIFEST_PATH=models/model_manifest.json
AI_ML_MODEL_MANIFEST_REQUIRED=false
AI_ML_METRIC_GATES_ENABLED=true
AI_ML_METRIC_MIN_AUTHENTICITY_F1=0.70
AI_ML_METRIC_MIN_AUTHENTICITY_ACCURACY=0.70
AI_ML_METRIC_MIN_SIGNATURE_F1=0.90
AI_ML_METRIC_MIN_SIGNATURE_ACCURACY=0.90
AI_ML_METRIC_MIN_RVL_CDIP_MACRO_F1=0.60
AI_ML_METRIC_MIN_MIDV500_MACRO_F1=0.40
